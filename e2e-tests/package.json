{
  "name": "user-interface-tests",
  "version": "1.0.0",
  "description": "Test automation for Checkout FE",
  "author": "Fernando Granato",
  "license": "MIT",
  "scripts": {
    "test": "dotenv -e .env jest --detectOpenHandles --reporters=jest-junit",
    "test:bdd": "dotenv -e uat.env -- npx cucumber-js",
    "test:bdd:tags": "dotenv -e uat.env -- npx cucumber-js --tags",
    "lint": "eslint . -c .eslintrc.json"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.15.4",
    "@babel/preset-typescript": "^7.24.1",
    "@cucumber/cucumber": "^12.8.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.49.0",
    "expect": "^30.3.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-puppeteer": "^11.0.0",
    "puppeteer": "^22.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  }
}
