							"  url: pm.environment.get(\"CHECKOUT_HOST\") + \"/ecommerce/checkout/v2/payment-methods\",",
							"  method: 'POST',",
							"   header: {",
							"    'Content-Type': 'application/json',",
							"  },",
							"  body: {",
							"    mode: 'raw',",
							"    raw: JSON.stringify(paymentMethodBodyRequest)",
							"  }",
							"};",
							"",
							"pm.sendRequest(postAllPaymentMethods, (error, response) => {",
							"  if (error) {",
